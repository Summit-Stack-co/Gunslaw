# Supabase — public (browser + SSR session refresh)
NEXT_PUBLIC_SUPABASE_URL=
# Use either publishable key (dashboard label may vary) or legacy anon key:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — required for POST /api/sms-consent and POST /api/contact (copy “service_role” from Supabase → Settings → API)
# This is NOT the anon/publishable key.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only — required for POST /api/contact email notifications
RESEND_API_KEY=
CONTACT_TO_EMAIL=
# Optional override; defaults to noreply@gunslaw.com
CONTACT_FROM_EMAIL=
